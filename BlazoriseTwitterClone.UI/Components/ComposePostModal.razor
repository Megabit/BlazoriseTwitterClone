@inject TwitterDataService DataService
@inject IModalService ModalService

<ModalContent Background="Background.White" Border="Border.Rounded" Width="Width.Is100" Overflow="Overflow.Hidden">
    <ModalBody Padding="Padding.Is0" Width="Width.Is100">
        <Div Padding="Padding.Is3" Flex="Flex.AlignItems.Center.JustifyContent.Between" Width="Width.Is100">
            <Button Background="Background.Transparent"
                    TextColor="TextColor.Dark"
                    Border="Border.Is0.RoundedCircle"
                    Width="Width.Rem( 2.5 )"
                    Height="Height.Rem( 2.5 )"
                    Clicked="@Close">
                X
            </Button>
            <Anchor To="#" TextColor="TextColor.Primary" TextWeight="TextWeight.SemiBold" Unstyled>Drafts</Anchor>
        </Div>

        <Div Padding="Padding.Is3.OnX.Is2.FromBottom" Flex="Flex.AlignItems.Start" Gap="Gap.Is3" Width="Width.Is100">
            <Avatar Source="@DataService.CurrentUser.AvatarUrl" Text="@DataService.CurrentUser.DisplayName" Size="2.5" />

            <Div Flex="Flex.Column" Gap="Gap.Is3" Width="Width.Is100">
                <Div>
                    <Button Color="Color.Light" Size="Size.Small" TextColor="TextColor.Primary" TextWeight="TextWeight.Bold">
                        Everyone
                        <Icon Name="@FluentUIIcons.ChevronDown" />
                    </Button>
                </Div>

                <MemoInput @bind-Text="@postText"
                           Placeholder="What's happening?"
                           Rows="4"
                           AutoSize
                           Plaintext
                           Border="Border.Is0"
                           Background="Background.White"
                           Width="Width.Is100"
                           TextSize="TextSize.Large" />

                <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is2" TextColor="TextColor.Primary" TextWeight="TextWeight.Bold" TextSize="TextSize.Small">
                    <Icon Name="@FluentUIIcons.Globe" />
                    <Span>Everyone can reply</Span>
                </Div>
            </Div>
        </Div>

        <Div Border="Border.Is1.OnTop" Padding="Padding.Is3" Flex="Flex.AlignItems.Center.JustifyContent.Between" Width="Width.Is100">
            <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is3" TextColor="TextColor.Primary">
                <Icon Name="@FluentUIIcons.Image" />
                <Icon Name="@FluentUIIcons.Gif" />
                <Icon Name="@FluentUIIcons.Poll" />
                <Icon Name="@FluentUIIcons.Emoji" />
                <Icon Name="@FluentUIIcons.Camera" />
                <Icon Name="@FluentUIIcons.Location" />
                <Icon Name="@FluentUIIcons.Flag" />
            </Div>

            <Button Color="Color.Primary" Border="Border.RoundedPill" TextWeight="TextWeight.Bold" Disabled="@string.IsNullOrWhiteSpace( postText )" Clicked="@Post">
                Post
            </Button>
        </Div>
    </ModalBody>
</ModalContent>

@code {
    private string postText = string.Empty;

    private Task Close()
    {
        return ModalService.Hide();
    }

    private Task Post()
    {
        return ModalService.Hide();
    }
}
