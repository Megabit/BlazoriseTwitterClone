@inject TwitterDataService DataService

<Div Border="Border.Is1.OnBottom" Padding="Padding.Is3" Flex="Flex.Default.NoWrap" Gap="Gap.Is2">
    <Avatar Source="@Tweet.AvatarUrl" Text="@Tweet.Author" Size="2.5" To="@ProfileUrl" Title="@($"Open profile for {Tweet.Author}")" />

    <Div Flex="Flex.Column" Width="Width.Is100">
        <Div Flex="Flex.AlignItems.Center.JustifyContent.Between">
            <Div Position="Position.Relative">
                <Span TextWeight="TextWeight.Bold">@Tweet.Author</Span>
                @if ( Tweet.Verified )
                {
                    <Span TextColor="TextColor.Primary">*</Span>
                }
                <Span TextColor="TextColor.Muted"> @Tweet.Handle - @Tweet.Time</Span>
                <Anchor To="@ProfileUrl" Title="@($"Open profile for {Tweet.Author}")" Stretched></Anchor>
            </Div>
            <Icon Name="@FluentUIIcons.MoreHorizontal" TextColor="TextColor.Muted" IconSize="IconSize.Large" />
        </Div>

        <Div Position="Position.Relative" Margin="Margin.Is1.FromTop">
            @foreach ( var line in Tweet.Body.Split( '\n' ) )
            {
                <Div>@line</Div>
            }

            @if ( NavigateOnClick )
            {
                <Anchor To="@PostUrl" Title="@($"Open post by {Tweet.Author}")" Stretched></Anchor>
            }
        </Div>

        @if ( !string.IsNullOrWhiteSpace( Tweet.QuotedBody ) )
        {
            <Card Border="Border.Is1" Margin="Margin.Is3.FromTop">
                <CardBody Padding="Padding.Is3">
                    <Div Position="Position.Relative">
                        <Span TextWeight="TextWeight.Bold">@Tweet.QuotedAuthor</Span>
                        <Span TextColor="TextColor.Muted"> @Tweet.QuotedHandle</Span>
                        @if ( !string.IsNullOrWhiteSpace( Tweet.QuotedHandle ) )
                        {
                            <Anchor To="@DataService.GetProfileUrl( Tweet.QuotedHandle )" Title="@($"Open profile for {Tweet.QuotedAuthor}")" Stretched></Anchor>
                        }
                    </Div>
                    <Div TextColor="TextColor.Dark">@Tweet.QuotedBody</Div>
                </CardBody>
            </Card>
        }

        @if ( Tweet.PollOptions is not null )
        {
            <Div Flex="Flex.Column" Gap="Gap.Is1" Margin="Margin.Is3.FromTop">
                @foreach ( var option in Tweet.PollOptions )
                {
                    <Button Color="Color.Primary" Outline Width="Width.Is100" Size="Size.Small" TextWeight="TextWeight.Bold" @onclick:stopPropagation>
                        @option.Label
                    </Button>
                }
                @if ( !string.IsNullOrWhiteSpace( Tweet.PollFooter ) )
                {
                    <Div TextColor="TextColor.Muted" TextSize="TextSize.Small" Margin="Margin.Is2.FromTop">@Tweet.PollFooter</Div>
                }
            </Div>
        }

        <Div Flex="Flex.JustifyContent.Between" TextColor="TextColor.Secondary" Margin="Margin.Is3.FromTop" Padding="Padding.Is1.FromEnd">
            <TweetMetric IconName="@FluentUIIcons.Comment" Value="@Tweet.Replies.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.ArrowRepeatAll" Value="@Tweet.Reposts.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.Heart" Value="@Tweet.Likes.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.ChartMultiple" Value="@Tweet.Views" />
            <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is3">
                <Icon Name="@FluentUIIcons.Bookmark" IconSize="IconSize.Large" />
                <Icon Name="@FluentUIIcons.Share" IconSize="IconSize.Large" />
            </Div>
        </Div>
    </Div>

</Div>

@code {
    [Parameter, EditorRequired] public Tweet Tweet { get; set; } = default!;

    [Parameter] public bool NavigateOnClick { get; set; } = true;

    private string PostUrl => $"/post/{Uri.EscapeDataString( Tweet.Id )}";

    private string ProfileUrl => DataService.GetProfileUrl( Tweet.Handle );
}
