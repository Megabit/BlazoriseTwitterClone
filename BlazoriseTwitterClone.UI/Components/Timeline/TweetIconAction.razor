<Tooltip Text="@TooltipText" Placement="TooltipPlacement.Top" ShowArrow Inline>
    <Icon Name="@IconName" IconSize="@IconSize" />
</Tooltip>

@code {
    [Parameter] public string IconName { get; set; } = string.Empty;

    [Parameter] public string TooltipText { get; set; } = string.Empty;

    [Parameter] public IconSize IconSize { get; set; } = IconSize.Default;
}
