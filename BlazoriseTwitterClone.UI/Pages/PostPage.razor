@page "/post/{TweetId}"
@inject TwitterDataService DataService
@inject NavigationManager NavigationManager

<Div Border="Border.Is1.OnBottom" Position="Position.Sticky.Top.Is0" Background="Background.White">
    <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is3" Padding="Padding.Is2.OnX.Is1.OnY">
        <Button Color="Color.Light" Clicked="@GoBack">
            <Icon Name="@FluentUIIcons.ArrowLeft" />
        </Button>
        <Div TextWeight="TextWeight.Bold" TextSize="TextSize.Large">Post</Div>
    </Div>
</Div>

@if ( tweet is null )
{
    <Div Height="Height.Px( 500 )" Flex="Flex.AlignItems.Center.JustifyContent.Center" TextColor="TextColor.Muted">
        Post not found
    </Div>
}
else
{
    <TweetCard Tweet="@tweet" NavigateOnClick="false" />

    <Div Padding="Padding.Is3" Border="Border.Is1.OnBottom">
        <Div TextColor="TextColor.Muted">
            5:42 PM - Apr 19, 2026 - <Span TextColor="TextColor.Dark" TextWeight="TextWeight.Bold">@tweet.Views</Span> Views
        </Div>
    </Div>

    <Div Border="Border.Is1.OnBottom" Padding="Padding.Is3">
        <Div Flex="Flex.JustifyContent.Between" TextColor="TextColor.Secondary">
            <TweetMetric IconName="@FluentUIIcons.Comment" Value="@tweet.Replies.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.ArrowRepeatAll" Value="@tweet.Reposts.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.Heart" Value="@tweet.Likes.ToString()" />
            <TweetMetric IconName="@FluentUIIcons.Bookmark" Value="83" />
            <Icon Name="@FluentUIIcons.Share" IconSize="IconSize.Large" />
        </Div>
    </Div>

    <Div Border="Border.Is1.OnBottom" Padding="Padding.Is3" Flex="Flex.AlignItems.Center" Gap="Gap.Is3">
        <Avatar Source="@DataService.CurrentUser.AvatarUrl" Text="@DataService.CurrentUser.DisplayName" Size="2.5" />
        <Div TextColor="TextColor.Muted" TextSize="TextSize.Large" Width="Width.Is100">Post your reply</Div>
        <Button Color="Color.Secondary" TextWeight="TextWeight.Bold">Reply</Button>
    </Div>

    <Div Padding="Padding.Is2.OnX" TextSize="TextSize.Small" TextColor="TextColor.Muted" Border="Border.Is1.OnBottom">
        Relevant
    </Div>

    @foreach ( var comment in DataService.GetCommentsFor( tweet.Id ) )
    {
        <Div Border="Border.Is1.OnBottom" Padding="Padding.Is3" Flex="Flex.Default.NoWrap" Gap="Gap.Is2">
            <Avatar Source="@comment.AvatarUrl" Text="@comment.Author" Size="2.5" To="@DataService.GetProfileUrl( comment.Handle )" Title="@($"Open profile for {comment.Author}")" />
            <Div Flex="Flex.Column" Width="Width.Is100">
                <Div Flex="Flex.AlignItems.Center.JustifyContent.Between">
                    <Div Position="Position.Relative">
                        <Span TextWeight="TextWeight.Bold">@comment.Author</Span>
                        @if ( comment.Verified )
                        {
                            <Span TextColor="TextColor.Primary">*</Span>
                        }
                        <Span TextColor="TextColor.Muted"> @comment.Handle - @comment.Time</Span>
                        <Anchor To="@DataService.GetProfileUrl( comment.Handle )" Title="@($"Open profile for {comment.Author}")" Stretched></Anchor>
                    </Div>
                    <Icon Name="@FluentUIIcons.MoreHorizontal" TextColor="TextColor.Muted" />
                </Div>

                <Div Margin="Margin.Is1.FromTop">
                    @foreach ( var line in comment.Body.Split( '\n' ) )
                    {
                        <Div TextColor="@(line.StartsWith( "Replying to ", StringComparison.Ordinal ) ? TextColor.Muted : TextColor.Default)">@line</Div>
                    }
                </Div>

                <Div Flex="Flex.JustifyContent.Between" TextColor="TextColor.Secondary" Margin="Margin.Is3.FromTop" Padding="Padding.Is1.FromEnd">
                    <TweetMetric IconName="@FluentUIIcons.Comment" Value="@comment.Replies.ToString()" />
                    <TweetMetric IconName="@FluentUIIcons.ArrowRepeatAll" Value="@comment.Reposts.ToString()" />
                    <TweetMetric IconName="@FluentUIIcons.Heart" Value="@comment.Likes.ToString()" />
                    <TweetMetric IconName="@FluentUIIcons.ChartMultiple" Value="@comment.Views" />
                    <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is3">
                        <Icon Name="@FluentUIIcons.Bookmark" />
                        <Icon Name="@FluentUIIcons.Share" />
                    </Div>
                </Div>
            </Div>
        </Div>
    }
}

@code {
    private Tweet? tweet;

    [Parameter] public string TweetId { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        tweet = DataService.GetTweetById( TweetId );
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo( "/" );
    }
}
