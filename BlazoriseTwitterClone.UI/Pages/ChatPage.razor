@page "/chat"
@layout BlazoriseTwitterClone.UI.Layout.ChatLayout
@inject TwitterDataService DataService

<Div Width="Width.Px( 340 )" Height="Height.Px( 760 )" Border="Border.Is1.Light.OnEnd" Flex="Flex.Column">
    <Div Flex="Flex.AlignItems.Center.JustifyContent.Between" Padding="Padding.Is3">
        <Div TextSize="TextSize.Heading5" TextWeight="TextWeight.Bold">Chat</Div>
        <Div Flex="Flex.AlignItems.Center" Gap="Gap.Is2">
            <Button Size="Size.Small" Color="Color.Light">All</Button>
            <Button Size="Size.Small" Color="Color.Light"><Icon Name="@FluentUIIcons.Compose" /></Button>
        </Div>
    </Div>
    <Div Padding="Padding.Is3.OnX.Is2.FromBottom">
        <TextInput Placeholder="Search" Role="TextRole.Search" />
    </Div>
    <Div Flex="Flex.Column">
        @foreach ( var conversation in DataService.Conversations )
        {
            <ConversationRow Conversation="@conversation" />
        }
    </Div>
</Div>

<Div Width="Width.Px( 834 )" Height="Height.Px( 760 )" Flex="Flex.AlignItems.Center.JustifyContent.Center" Border="Border.Is1.Light.OnEnd">
    <Div Flex="Flex.Column.AlignItems.Center" Gap="Gap.Is2">
        <Div Background="Background.Light" Border="Border.RoundedCircle" Padding="Padding.Is5">
            <Icon Name="@FluentUIIcons.ChatEmpty" IconSize="IconSize.Large" />
        </Div>
        <Div TextSize="TextSize.Heading5" TextWeight="TextWeight.Bold">Start Conversation</Div>
        <Div TextColor="TextColor.Muted">Choose from your existing conversations, or start a new one.</Div>
        <Button Color="Color.Dark" TextWeight="TextWeight.Bold" Margin="Margin.Is3.FromTop">New chat</Button>
    </Div>
</Div>
